{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "resources", "serviceAccount", "metrics"],
  "definitions": {
    "dnsLabel": {
      "type": "string",
      "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
      "maxLength": 63
    },
    "namespace": {
      "type": "string",
      "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
      "maxLength": 63
    },
    "objectMap": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "resources": {
      "type": "object",
      "required": ["requests", "limits"],
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      }
    }
  },
  "properties": {
    "global": { "type": "object" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "namespaceOverride": { "$ref": "#/definitions/namespace" },
    "commonLabels": { "$ref": "#/definitions/objectMap" },
    "commonAnnotations": { "$ref": "#/definitions/objectMap" },
    "image": {
      "type": "object",
      "required": ["registry", "repository", "tag", "pullPolicy"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "pullSecrets": { "type": "array" }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "controller": {
      "type": "object",
      "properties": {
        "leaderElection": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "extraArgs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "clusterProfileProvider": {
          "type": "object",
          "required": ["enabled", "providerFilePath", "providerName", "credentialsCommand"],
          "properties": {
            "enabled": { "type": "boolean" },
            "providerFilePath": { "type": "string", "pattern": "^/" },
            "providerName": { "type": "string", "minLength": 1 },
            "credentialsCommand": { "type": "string", "pattern": "^/" }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "required": ["create", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "$ref": "#/definitions/dnsLabel" },
        "annotations": { "$ref": "#/definitions/objectMap" },
        "labels": { "$ref": "#/definitions/objectMap" }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "$ref": "#/definitions/objectMap" }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["containerPort", "service"],
      "properties": {
        "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "service": {
          "type": "object",
          "required": ["enabled", "type", "port"],
          "properties": {
            "enabled": { "type": "boolean" },
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
            },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "$ref": "#/definitions/objectMap" }
          }
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "namespace": { "$ref": "#/definitions/namespace" },
        "labels": { "$ref": "#/definitions/objectMap" },
        "annotations": { "$ref": "#/definitions/objectMap" },
        "interval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "path": { "type": "string", "pattern": "^/" },
        "scheme": { "type": "string", "enum": ["http", "https"] },
        "bearerTokenFile": { "type": "string", "pattern": "^/" },
        "tlsConfig": {
          "type": "object",
          "properties": {
            "insecureSkipVerify": { "type": "boolean" },
            "serverName": { "type": "string" }
          }
        },
        "honorLabels": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "scheme": { "const": "https" } },
            "required": ["scheme"]
          },
          "then": { "required": ["tlsConfig"] }
        }
      ]
    },
    "containerPorts": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "resources": { "$ref": "#/definitions/resources" },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "podLabels": { "$ref": "#/definitions/objectMap" },
    "podAnnotations": { "$ref": "#/definitions/objectMap" },
    "podAutomountServiceAccountToken": { "type": "boolean" },
    "deploymentAnnotations": { "$ref": "#/definitions/objectMap" },
    "priorityClassName": { "type": "string" },
    "schedulerName": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "extraEnvVars": { "type": "array" },
    "extraEnvVarsCM": { "type": "string" },
    "extraEnvVarsSecret": { "type": "string" },
    "extraVolumeMounts": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "initContainers": { "type": "array" },
    "sidecars": { "type": "array" }
  }
}
